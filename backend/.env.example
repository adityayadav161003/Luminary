# Luminary Backend Environment Variables

# OpenRouter API key — only query text is transmitted, never PDF bytes
OPENROUTER_API_KEY="your_openrouter_api_key_here"

# Clerk authentication
CLERK_SECRET_KEY="sk_test_..."
CLERK_JWKS_URL="https://your_clerk_url/.well-known/jwks.json"

# CORS — set to your Vercel frontend domain in production
ALLOWED_ORIGIN=*

# Storage
FAISS_INDEX_PATH=./faiss_store
DATABASE_URL=sqlite+aiosqlite:///./luminary.db
